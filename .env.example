# Epocheye mobile app environment variables.
# Copy to .env and fill in real values. Never commit .env.

# Google Maps (Android/iOS Places + Maps SDK)
GOOGLE_MAPS_API_KEY=

# Backend base URL (Go API on API Gateway)
baseUrl=

# Razorpay checkout (public key only; secret stays server-side)
RAZORPAY_KEY_ID=

# Gemini (Google AI Studio) — used for monument vision + image generation
GEMINI_API_KEY=

# EfficientSAM HD scan Lambda endpoint (optional)
SAM_LAMBDA_URL=
